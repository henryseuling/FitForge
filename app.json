{
  "expo": {
    "name": "FitForge",
    "slug": "FitForge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitforge",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.henryseuling.fitforge",
      "infoPlist": {
        "NSCameraUsageDescription": "FitForge uses the camera to snap photos of meals for nutrition tracking.",
        "NSHealthShareUsageDescription": "FitForge reads your health data to personalize workout readiness and recovery.",
        "NSHealthUpdateUsageDescription": "FitForge writes workout data to keep your health records up to date.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0C0C14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store",
      [
        "react-native-health",
        {
          "healthSharePermission": "FitForge reads your health data to personalize workout readiness and recovery.",
          "healthUpdatePermission": "FitForge writes workout data to keep your health records up to date.",
          "isClinicalDataEnabled": false
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://sopehnasvzeleoriztjd.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNvcGVobmFzdnplbGVvcml6dGpkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIzMDA1NjYsImV4cCI6MjA4Nzg3NjU2Nn0.hXRSFxTK7ugsSd63l8Niy6TJA_wk-fQH_vy9PIvrwsw",
